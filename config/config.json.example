{
  "providers": {
    "tyc": { "token": "<YOUR_TYC_TOKEN>" },
    "dnb": { "token": "<YOUR_DNB_TOKEN>" }
  },
  "apis": {
    "819": {
      "name": "企业基本信息（含主要人员）",
      "url": "http://open.api.tianyancha.com/services/open/ic/baseinfoV3/2.0",
      "provider": "tyc",
      "timeout": 30
    },
    "1058": {
      "name": "企业天眼风险",
      "url": "http://open.api.tianyancha.com/services/open/risk/riskInfo/2.0",
      "provider": "tyc",
      "timeout": 30
    },
    "822": {
      "name": "变更记录",
      "url": "http://open.api.tianyancha.com/services/open/ic/changeinfo/2.0",
      "provider": "tyc",
      "timeout": 30
    },
    "854": {
      "name": "上市公司企业简介",
      "url": "http://open.api.tianyancha.com/services/open/stock/companyInfo/2.0",
      "provider": "tyc",
      "timeout": 30
    },
    "1168": {
      "name": "组织机构",
      "url": "http://open.api.tianyancha.com/services/open/ic/companyType/v2",
      "provider": "tyc",
      "timeout": 30
    },
    "1149": {
      "name": "企业规模",
      "url": "http://open.api.tianyancha.com/services/open/ic/scale",
      "provider": "tyc",
      "timeout": 30
    },
    "967": {
      "name": "主要指标-年度",
      "url": "http://open.api.tianyancha.com/services/open/stock/mainIndex/2.0",
      "provider": "tyc",
      "timeout": 30
    },
    "1114": {
      "name": "法律诉讼",
      "url": "http://open.api.tianyancha.com/services/open/jr/lawSuit/3.0",
      "provider": "tyc",
      "timeout": 30
    }
  },
  "mysql": {
    "host": "host.docker.internal",
    "port": 3306,
    "user": "<YOUR_DB_USER>",
    "password": "<YOUR_DB_PASSWORD>",
    "database": "powerlink",
    "charset": "utf8mb4"
  }
}