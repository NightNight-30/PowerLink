    "1149":  { "name": "企业规模",                 "url": "http://open.api.tianyancha.com/services/open/ic/companyScale/2.0", "provider": "tyc", "timeout": 30, "frequency": "daily", "prepaid_filter": true, "normal_error_codes": [300000], "charge_per_query": false },
    "967":   { "name": "主要指标-年度",             "url": "http://open.api.tianyancha.com/services/open/fin/mainindex/2.0", "provider": "tyc", "timeout": 30, "frequency": "monthly", "prepaid_filter": true, "normal_error_codes": [300000], "charge_per_query": false },
    "1114":  { "name": "法律诉讼",                 "url": "http://open.api.tianyancha.com/services/open/law/lawsuit/2.0", "provider": "tyc", "timeout": 30, "frequency": "daily", "prepaid_filter": true, "normal_error_codes": [300000], "charge_per_query": true },
    "1041":  { "name": "司法解析",                 "url": "http://open.api.tianyancha.com/services/open/jr/judicialCase/2.0", "provider": "tyc", "timeout": 30, "frequency": "daily", "prepaid_filter": true, "normal_error_codes": [300000], "charge_per_query": true },
    "973":   { "name": "现金流量表",               "url": "http://open.api.tianyancha.com/services/open/fin/cashflow/2.0", "provider": "tyc", "timeout": 30, "frequency": "monthly", "prepaid_filter": true, "normal_error_codes": [300000], "charge_per_query": false },
    "P51060": { "name": "付款指数（PAYDEX®）",      "url": "https://openapi.dnb.com.cn/v1/api/callDNBInterface", "provider": "dnb", "timeout": 30, "sku_no": "OPSP-10924-21", "api_id": "P51060", "frequency": "monthly", "prepaid_filter": true, "normal_error_codes": [1, 1021, 2001], "charge_per_query": false }
